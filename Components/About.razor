@page "/about"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>About - Study Planner</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h2 class="mb-4">About Study Planner</h2>
            
            <p class="lead">
                Study Planner is a simple and focused web application designed to help students — 
                especially online learners — manage their academic responsibilities more effectively.
            </p>

            <h5 class="mt-5">Our Goal</h5>
            <p>
                Many students struggle with balancing coursework, assignments, and personal life. 
                Traditional tools like notebooks or generic to-do apps often fall short. 
                Study Planner provides a clean, student-centered platform to organize tasks by subject, 
                track deadlines, and monitor progress.
            </p>

            <h5 class="mt-5">Key Features</h5>
            <ul class="list-group list-group-flush">
                <li class="list-group-item">✅ Create, edit, and delete study tasks</li>
                <li class="list-group-item">📅 Set deadlines for assignments</li>
                <li class="list-group-item">📚 Organize tasks by subject/course</li>
                <li class="list-group-item">✔️ Mark tasks as completed</li>
                <li class="list-group-item">🔒 Secure user accounts</li>
            </ul>

            <p class="mt-4 text-muted">
                This project was developed as part of Team 14's academic project.
            </p>
        </div>
    </div>
</div>