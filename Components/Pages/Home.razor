@page "/"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>Home - Study Planner</PageTitle>

<div class="container text-center py-5">
    <h1 class="display-4 mb-3">📚 Welcome to Study Planner</h1>
    <p class="lead mb-5">
        Your simple, focused tool to help you manage study tasks, subjects, and deadlines effectively.
    </p>

    <AuthorizeView>
        <Authorized>
            <div class="mb-4">
                <a href="/planner" class="btn btn-primary btn-lg px-5">
                    Go to My Dashboard →
                </a>
            </div>
            <p class="text-muted">Welcome back, @context.User.Identity?.Name!</p>
        </Authorized>
        <NotAuthorized>
            <div class="d-grid gap-3 d-sm-flex justify-content-sm-center">
                <a href="/Account/Register" class="btn btn-success btn-lg px-5">
                    Get Started - Register
                </a>
                <a href="/Account/Login" class="btn btn-outline-primary btn-lg px-5">
                    Login
                </a>
            </div>
        </NotAuthorized>
    </AuthorizeView>

    <!-- Features Section -->
    <div class="row mt-5 g-4">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">✅ Task Management</h5>
                    <p class="card-text">
                        Create, edit, delete, and mark your study tasks as completed with deadlines.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">📚 Organize by Subject</h5>
                    <p class="card-text">
                        Group your tasks by course or subject to stay focused on one area at a time.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">📅 Smart Deadlines</h5>
                    <p class="card-text">
                        Never miss an assignment again. Deadlines are clearly shown and highlighted.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>